{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:https": "next dev --webpack --experimental-https --experimental-https-key ./certs/server.key --experimental-https-cert ./certs/server.crt",
    "socket": "node socket-server.js",
    "build": "npx prisma generate && next build",
    "start": "node server-production.js",
    "start:next": "next start",
    "start:socket": "NODE_ENV=production node server.js",
    "postinstall": "npx prisma generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.3",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "typescript": "^5"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.3"
  }
}
